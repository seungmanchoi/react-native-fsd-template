    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
